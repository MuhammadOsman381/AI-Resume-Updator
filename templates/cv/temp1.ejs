<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8" />
  <title><%= name || "Resume" %></title>

  <script src="https://cdn.tailwindcss.com"></script>

  <style>
    @page {
      size: A4;
      margin: 12mm;
    }
  </style>
</head>

<body class="font-sans text-[12px] text-gray-800 leading-relaxed">

  <!-- HEADER -->
  <header class="mb-4">
    <div class="flex justify-between items-start">
      <div>
        <% if (name) { %>
          <h1 class="text-[24px] font-bold tracking-tight text-gray-900">
            <%= name %>
          </h1>
        <% } %>

        <% if (position) { %>
          <div class="text-[13px] text-gray-600 mt-1">
            <%= position %>
          </div>
        <% } %>
      </div>

      <% if (links && links.length > 0) { %>
        <div class="text-[11px] text-right space-y-1">
          <% links.forEach(link => { %>
            <% if (link) { %>
              <div><%= link %></div>
            <% } %>
          <% }) %>
        </div>
      <% } %>
    </div>

    <div class="border-b border-gray-300 mt-3"></div>
  </header>

  <!-- SUMMARY -->
  <% if (summary) { %>
    <section class="mb-4">
      <h2 class="text-[13px] font-bold uppercase tracking-wide text-gray-700 mb-1">
        Professional Summary
      </h2>
      <p class="text-[12px] text-gray-700">
        <%= summary %>
      </p>
    </section>
  <% } %>

  <!-- SKILLS -->
  <% if (tech_stack && tech_stack.length > 0) { %>
    <section class="mb-4">
      <h2 class="text-[13px] font-bold uppercase tracking-wide text-gray-700 mb-1">
        Skills
      </h2>
      <p class="text-[12px] text-gray-700">
        <%= tech_stack.join(" • ") %>
      </p>
    </section>
  <% } %>

  <!-- EXPERIENCE -->
  <% if (experience && experience.length > 0) { %>
    <section class="mb-4">
      <h2 class="text-[13px] font-bold uppercase tracking-wide text-gray-700 mb-2">
        Experience
      </h2>

      <% experience.forEach(exp => { %>
        <% if (exp.title || exp.description) { %>
          <div class="mb-3">

            <div class="flex justify-between items-center">
              <div class="font-semibold text-gray-900">
                <%= exp.title %>
                <% if (exp.company) { %>
                  <span class="font-normal text-gray-600">
                    — <%= exp.company %>
                  </span>
                <% } %>
              </div>

              <% if (exp.date) { %>
                <div class="text-[11px] text-gray-500">
                  <%= exp.date %>
                </div>
              <% } %>
            </div>

            <% if (exp.description) { %>
              <ul class="list-disc ml-4 mt-1 space-y-1 text-gray-700">
                <li><%= exp.description %></li>
              </ul>
            <% } %>

          </div>
        <% } %>
      <% }) %>
    </section>
  <% } %>

  <!-- PROJECTS -->
  <% if (projects && projects.length > 0) { %>
    <section class="mb-4">
      <h2 class="text-[13px] font-bold uppercase tracking-wide text-gray-700 mb-2">
        Projects
      </h2>

      <% projects.forEach(project => { %>
        <% if (project.title || project.description) { %>
          <div class="mb-3">

            <div class="font-semibold text-gray-900">
              <%= project.title %>
            </div>

            <% if (project.description) { %>
              <ul class="list-disc ml-4 mt-1 space-y-1 text-gray-700">
                <li><%= project.description %></li>
              </ul>
            <% } %>

            <% if (project.link) { %>
              <div class="text-[11px] mt-1">
                <span class="font-medium text-gray-700">Link:</span>
                <a href="<%= project.link %>" class="text-blue-600 underline">
                  <%= project.link %>
                </a>
              </div>
            <% } %>

          </div>
        <% } %>
      <% }) %>
    </section>
  <% } %>

  <!-- EDUCATION -->
  <% if (education && education.length > 0) { %>
    <section>
      <h2 class="text-[13px] font-bold uppercase tracking-wide text-gray-700 mb-2">
        Education
      </h2>

      <% education.forEach(edu => { %>
        <% if (edu.institute || edu.degree || edu.year) { %>
          <div class="flex justify-between mb-2">

            <div>
              <% if (edu.institute) { %>
                <div class="font-semibold text-gray-900">
                  <%= edu.institute %>
                </div>
              <% } %>

              <% if (edu.degree) { %>
                <div class="text-[11px] text-gray-600">
                  <%= edu.degree %>
                </div>
              <% } %>
            </div>

            <% if (edu.year) { %>
              <div class="text-[11px] text-gray-500">
                <%= edu.year %>
              </div>
            <% } %>

          </div>
        <% } %>
      <% }) %>
    </section>
  <% } %>

</body>
</html>