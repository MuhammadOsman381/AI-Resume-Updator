<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Cover Letter</title>
    <style>
        body {
            font-family: 'Times New Roman', Times, serif;
            line-height: 1.6;
            color: #333;
            margin: 40px;
            font-size: 11pt;
        }
        .header {
            margin-bottom: 30px;
        }
        .date {
            margin-bottom: 20px;
        }
        .content {
            white-space: pre-wrap;
        }
        .signature {
            margin-top: 40px;
        }
    </style>
</head>
<body>
    <div class="header">
        <strong><%= name %></strong><br>
        <% if (links && links.length > 0) { %>
            <%= links.join(' | ') %><br>
        <% } %>
    </div>

    <div class="date">
        <%= new Date().toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }) %>
    </div>

    <div class="recipient">
        To,<br>
        Hiring Manager,<br>
        <%= companyName %>
    </div>

    <div class="content">
<%= coverLetter %>
    </div>

    <div class="signature">
        Sincerely,<br>
        <strong><%= name %></strong>
    </div>
</body>
</html>
